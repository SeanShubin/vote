<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        JSON-formatted stdout. In Lambda this gets captured by the runtime and
        forwarded to CloudWatch Logs as structured events that Logs Insights
        can query by field. Local dev sees JSON too — pipe through `jq` if you
        want it pretty.
    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>true</includeMdcKeyName>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>

    <logger name="com.seanshubin.vote" level="DEBUG" />
    <logger name="aws" level="INFO" />
    <logger name="software.amazon" level="INFO" />
    <logger name="org.eclipse.jetty" level="INFO" />
</configuration>
